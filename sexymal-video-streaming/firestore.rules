rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Videos collection: allow public read, and write (for admin additions/deletions)
    match /videos/{videoId} {
      allow read, write: if true;
    }

    // Categories collection: allow public read, and write (for dynamic category updates)
    match /categories/{categoryName} {
      allow read, write: if true;
    }
  }
}
