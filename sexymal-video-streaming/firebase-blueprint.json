{
  "entities": {
    "Video": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "category": { "type": "string" },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "dislikes": { "type": "number" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string" },
        "muxPlaybackId": { "type": "string" }
      },
      "required": ["id", "title", "description", "videoUrl", "category", "views", "likes", "dislikes", "createdAt"]
    },
    "Category": {
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "videos": {
      "schema": "Video",
      "description": "Collection of all videos in the system"
    },
    "categories": {
      "schema": "Category",
      "description": "Collection of all active custom media categories"
    }
  }
}
